// link-keeper: 残しておきたいリンクを種類・話題で管理する個人ライブラリ
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  description String?
  url         String
  category    Category     @relation(fields: [categoryId], references: [id])
  categoryId  String
  type        ResourceType @relation(fields: [typeId], references: [id])
  typeId      String
  topic       Topic        @relation(fields: [topicId], references: [id])
  topicId     String
  status      Status?      @relation(fields: [statusId], references: [id])
  statusId    String?
  pinned      Boolean      @default(false)
  memo        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([categoryId])
  @@index([typeId])
  @@index([topicId])
  @@index([statusId])
}

// 大カテゴリ。「1年後にも使えるか」で二分する最上位の区分
//   知識 = 1年後も使える普遍的な内容 / 情報 = 旬で流動的、1年後には古びうる内容
model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  resources Resource[]
}

// テンプレート / 書籍 / 動画 / Skills・Plugin / 記事 など（準固定マスタ）
model ResourceType {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  resources Resource[]
}

// 話題（CC 7 個 + 記事テーマ 4 個）。単一選択の準固定マスタ
model Topic {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  resources Resource[]
}

// 実践状況（進捗）。未読 → 後で挑戦 → 実践済み（sortOrder 順に循環）
model Status {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  resources Resource[]
}
